   "source": [
    "import pyodbc\n",
    "import pandas as pd\n",
    "import re\n",
    "import unicodedata\n",
    "from datetime import datetime\n",
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "studies_data = pd.read_csv(\"${DEMENTIA_DATA_ROOT}\\Brain Age\\csv_data\\studies_data.csv\")\n",
    "#studies_data =  pd.read_csv(r\"${DEMENTIA_DATA_ROOT}\\Brain Age\\csv_data\\studies_data.csv\")\n",
    "id_MRN_data = studies_data[['PatientID','MRN','DateOfVisit']]\n",
    "id_MRN_data['DateOfVisit'] = pd.to_datetime(id_MRN_data['DateOfVisit'],format=\"%Y-%m-%d\")\n",
    "id_MRN_data['DateOfVisit'] = id_MRN_data['DateOfVisit'].dt.strftime('%Y-%m-%d')\n",
    "id_MRN_data"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Split into smaller chuncks for query"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {
    "collapsed": true
   },
   "outputs": [],
   "source": [
    "small_patient_chucks = np.array_split(np.array(id_MRN_data['PatientID']), 15)\n",
    "large_patient_chucks = np.array_split(np.array(id_MRN_data['PatientID']), 5)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "conn1 = pyodbc.connect('DRIVER={SQL Server};SERVER=<INTERNAL_DB>;DATABASE=Epic;UID=partners\<USER>;PWD=********;Trusted_Connection=yes')\n",
    "cursor1 = conn1.cursor()\n",
    "\n",
    "MedicationDiagnosisData = pd.DataFrame()\n",
    "i=0\n",
    "for chunk in small_patient_chucks:\n",
    "    data_Query = \"SELECT t2.[OrderID] as OrderMedicationID \\\n",
    "      ,t2.[PatientID] \\\n",
    "      ,t4.[ContactDTS] as ContactDTSForEncounter  \\\n",
    "      ,t2.[PatientEncounterID] \\\n",
    "      ,t2.[DiagnosisID] \\\n",
    "      ,t3.[DiagnosisNM] \\\n",
    "      ,t3.[DiagnosisGroupDSC] \\\n",
    "      ,t2.[CommentTXT] \\\n",
    "      ,t5.[OrderDTS] \\\n",
    "      ,t5.MedicationID \\\n",
    "      ,t5.MedicationDSC \\\n",
    "      ,t5.SigTXT \\\n",
    "      ,t5.PrescriptionQuantityNBR \\\n",
    "      ,t5.StartDTS as StartDTSForMedication \\\n",
    "      ,t5.EndDTS as EndDTSForMedication \\\n",
    "      ,t5.DiscreteFrequencyID \\\n",
    "      ,t5.DiscreteFrequencyDSC \\\n",
    "     FROM [Epic].[Orders].[DiagnosisMedication_MGH] t2 \\\n",
    "     inner join [Epic].[Reference].[ICDDiagnosis] t3 ON t2.DiagnosisID = t3.DiagnosisID \\\n",
    "     left join  [Epic].[Encounter].[Appointment_MGH] t4 ON t2.PatientEncounterID = t4.PatientEncounterID \\\n",
    "     left join [Epic].[Orders].[Medication_MGH] t5 ON t2.OrderID = t5.OrderID \\\n",
    "     WHERE t2.PatientID IN ('\" + \"','\".join(chunk)  + \"')\"\n",
    "    \n",
    "    i=i+1\n",
    "    print(\"chunk:\",i)\n",
    "    cursor1.execute(data_Query)\n",
    "    data = cursor1.fetchall()\n",
    "    data_labels = ['OrderMedicationID' \n",
    "    ,'PatientID' \n",
    "    ,'ContactDTSForEncounter'\n",
    "    ,'PatientEncounterID'\n",
    "    ,'DiagnosisID'\n",
    "    ,'DiagnosisNM'\n",
    "    ,'DiagnosisGroupDSC'\n",
    "    ,'CommentTXT'\n",
    "    ,'OrderDTS'\n",
    "    ,'MedicationID'\n",
    "    ,'MedicationDSC'\n",
    "    ,'SigTXT'\n",
    "    ,'PrescriptionQuantityNBR'\n",
    "    ,'StartDTSForMedication'\n",
    "    ,'EndDTSForMedication'\n",
    "    ,'DiscreteFrequencyID'\n",
    "    ,'DiscreteFrequencyDSC']\n",
    "    df  = pd.DataFrame.from_records(data,columns=data_labels)\n",
    "    print(df.iloc[100,:])\n",
    "    MedicationDiagnosisData = pd.concat([MedicationDiagnosisData,df])\n",
    "conn1.close()\n",
    "MedicationDiagnosisData"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
