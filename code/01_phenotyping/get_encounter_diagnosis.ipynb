   "source": [
    "import pyodbc\n",
    "import pandas as pd\n",
    "import re\n",
    "import unicodedata\n",
    "from datetime import datetime\n",
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "studies_data = pd.read_csv(\"${DEMENTIA_DATA_ROOT}\\Brain Age\\csv_data\\studies_data.csv\")\n",
    "#studies_data =  pd.read_csv(r\"${DEMENTIA_DATA_ROOT}\\Brain Age\\csv_data\\studies_data.csv\")\n",
    "id_MRN_data = studies_data[['PatientID','MRN','DateOfVisit']]\n",
    "id_MRN_data['DateOfVisit'] = pd.to_datetime(id_MRN_data['DateOfVisit'],format=\"%Y-%m-%d\")\n",
    "id_MRN_data['DateOfVisit'] = id_MRN_data['DateOfVisit'].dt.strftime('%Y-%m-%d')\n",
    "id_MRN_data"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Split into smaller chunks for query"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {
    "collapsed": true
   },
   "outputs": [],
   "source": [
    "small_patient_chucks = np.array_split(np.array(id_MRN_data['PatientID']), 15)\n",
    "large_patient_chucks = np.array_split(np.array(id_MRN_data['PatientID']), 5)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "len(small_patient_chucks[0])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "################ Table for Encounter.PatientEncounterDiagnosis ####################################\n",
    " \n",
    "conn1 = pyodbc.connect('DRIVER={SQL Server};SERVER=<INTERNAL_DB>;DATABASE=Epic;UID=partners\<USER>;PWD=********;Trusted_Connection=yes')\n",
    "cursor1 = conn1.cursor()\n",
    "\n",
    "EncounterDiagnosisData = pd.DataFrame()\n",
    "for chunk in small_patient_chucks:\n",
    "    data_Query = \"SELECT \\\n",
    "        [PatientEncounterID]  \\\n",
    "        ,[PatientID] \\\n",
    "        ,ContactDTS \\\n",
    "        ,t1.[DiagnosisID] \\\n",
    "        ,t2.[DiagnosisNM]  \\\n",
    "        ,t2.[DiagnosisGroupDSC] \\\n",
    "        ,[CommentTXT] \\\n",
    "        ,[ICD9DiagnosisStageID] \\\n",
    "        ,[EDDiagnosisID] \\\n",
    "        FROM [Epic].[Encounter].[PatientEncounterDiagnosis_MGH] t1 \\\n",
    "        inner join [Epic].[Reference].[ICDDiagnosis] t2 ON t1.DiagnosisID = t2.DiagnosisID \\\n",
    "        WHERE PatientID IN ('\" + \"','\".join(chunk)  + \"')\"\n",
    "    cursor1.execute(data_Query)\n",
    "    data = cursor1.fetchall()\n",
    "    data_labels = ['PatientEncounterID' \n",
    "    ,'PatientID' \n",
    "    ,'ContactDTSForEncounter' \n",
    "    ,'DiagnosisID'\n",
    "    ,'DiagnosisNM'\n",
    "    ,'DiagnosisGroupDSC'\n",
    "    ,'CommentTXT'\n",
    "    ,'ICD9DiagnosisStageID'\n",
    "    ,'EDDiagnosis']\n",
    "    df  = pd.DataFrame.from_records(data,columns=data_labels)\n",
    "    EncounterDiagnosisData = pd.concat([EncounterDiagnosisData,df])\n",
    "conn1.close()\n",
    "EncounterDiagnosisData"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "metadata": {
    "collapsed": true
   },
